# ===========================================
# Multi-Modal Finance Copilot — Environment
# ===========================================

# Groq API Key (Required for chat, routing, HyDE)
GROQ_API_KEY=

# Ollama (local) — used for evaluation only
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest

# Groq model names
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview

# Vision strategy: 'true' = use Groq Vision API, 'false' = local HuggingFace (default)
USE_GROQ_VISION=false

# UK Companies House API (optional, free registration)
# https://developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=

# Windows: Path to Poppler 'bin' folder (required for high-res layout analysis)
# Example: C:\Program Files\poppler\Library\bin
POPPLER_PATH=

# Windows: Path to Tesseract-OCR folder (required for OCR in high-res parser)
# Example: C:\Program Files\Tesseract-OCR
TESSERACT_PATH=

